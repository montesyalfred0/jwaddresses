# ========================================
# JW Addresses - Environment Variables
# ========================================
# Copy this file to .env (project root) and adjust values.
# These variables are used by docker-compose.yml.

# PostgreSQL
DB_USER=jwapp
DB_NAME=jwaddresses
DB_PASSWORD=change_this_password

# Redis
REDIS_PASSWORD=change_this_redis_password

# (Los puertos 80 y 443 son manejados por Traefik)

# ========================================
# backend/.env also needs to be created separately.
# ========================================
